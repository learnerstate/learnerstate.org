---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blogs");
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} · Resources · Learner State Layer`}
  description={`${post.data.title} — a blog post from the Learner State community.`}
  bodyClass="blog-post-page"
  ogType="article"
>
  <section class="blog-post-rendering">
    <article class="prose blog-post-content">
      <div class="blog-post-content-head">
        <p class="label">Resources / Blogs</p>
        <a
          class="src-link"
          href={`https://github.com/learnerstate/Resources/blob/main/blogs/${post.data.slug}.md`}
          target="_blank"
          rel="noopener"
        >
          View source on GitHub
        </a>
      </div>
      <Content />
    </article>
  </section>
</BaseLayout>

<style>
  .blog-post-rendering {
    width: min(76rem, calc(100vw - 3rem));
    margin-inline: auto;
    padding: 3rem 0 4.5rem;
  }

  .blog-post-content {
    max-width: 68rem;
    margin-inline: auto;
    padding: 1.4rem;
  }

  .blog-post-content-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .src-link {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    color: var(--fg-secondary);
    text-decoration: none;
    font-size: 0.84rem;
    font-weight: 600;
  }

  .src-link:hover {
    color: var(--fg);
    background: var(--bg-elevated);
    border-color: var(--border-strong);
    text-decoration: none;
  }

  .blog-post-content :global(h1) {
    margin-top: 0;
  }

  .blog-post-content :global(h2) {
    margin-top: 1.6rem;
  }

  @media (min-width: 900px) {
    :global(body.blog-post-page main.wrap) {
      max-width: none;
      padding-inline: 0;
    }

    .blog-post-rendering {
      padding-top: 4rem;
    }
  }
</style>
