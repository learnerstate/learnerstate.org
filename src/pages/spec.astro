---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Toc from "../components/Toc.astro";
import MermaidLoader from "../components/MermaidLoader.astro";

const [specEntry] = await getCollection("spec");

if (!specEntry) {
  throw new Error(
    "Spec content missing. Run `npm run fetch:spec` before building or developing.",
  );
}

const { Content, headings } = await render(specEntry);
const hasMermaid = specEntry.body?.includes("```mermaid") ?? false;
const fetchedDate = specEntry.data.fetchedAt
  ? new Date(specEntry.data.fetchedAt).toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
      timeZone: "UTC",
    })
  : null;
---

<BaseLayout
  title="Learner State Layer Specification v1.0"
  description="The core specification for Learner State Layer: a portable snapshot of what a person knows."
  bodyClass="spec-page"
>
  <section class="spec-hero">
    <div class="spec-copy">
      <p class="label">Specification</p>
      <h1>Portable learner state, defined clearly.</h1>
      <p class="spec-lead">
        LSL is a compact, portable snapshot of what a learner knows now, what they still need to
        work on, and how confident each claim is.
      </p>
      <div class="spec-meta">
        <span class="badge">v1.0-draft</span>
        {fetchedDate && <span class="spec-date">Updated {fetchedDate}</span>}
      </div>
    </div>

    <div class="spec-summary">
      <div class="summary-row">
        <span class="summary-key">Core</span>
        <span class="summary-value">concepts, mastery, confidence, freshness</span>
      </div>
      <div class="summary-row">
        <span class="summary-key">Core signals</span>
        <span class="summary-value">can, cannot_yet, misconceptions, next</span>
      </div>
      <div class="summary-row">
        <span class="summary-key">Extensions</span>
        <span class="summary-value">provenance, relationships, federation</span>
      </div>
    </div>
  </section>

  <section class="spec-shell">
    <aside class="spec-sidebar">
      <Toc headings={headings} />
    </aside>
    <article class="prose spec-content">
      <div class="spec-content-head">
        <a
          class="src-link"
          href="https://github.com/learnerstate/lsl/blob/main/SPEC.md"
          target="_blank"
          rel="noopener"
        >
          View source on GitHub
        </a>
      </div>
      <Content />
    </article>
  </section>
</BaseLayout>

{hasMermaid && <MermaidLoader />}

<style>
  .spec-hero {
    display: grid;
    gap: 1rem;
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--border);
  }

  .spec-copy {
    max-width: 42rem;
  }

  .spec-copy h1 {
    margin-top: 0.35rem;
    margin-bottom: 0.85rem;
    max-width: 14ch;
  }

  .spec-lead {
    margin: 0;
    max-width: 40rem;
    color: var(--fg-secondary);
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .spec-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.1rem;
  }

  .spec-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .spec-summary {
    display: grid;
    gap: 0.8rem;
    padding: 1.2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.82);
    box-shadow: var(--shadow-sm);
  }

  .summary-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(31, 29, 26, 0.08);
  }

  .summary-row:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .summary-key {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    flex-shrink: 0;
  }

  .summary-value {
    color: var(--fg);
    text-align: right;
  }

  .spec-shell {
    display: grid;
    gap: 1.5rem;
    padding: 2rem 0 4.5rem;
  }

  .spec-content-head {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1rem;
  }

  .src-link {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    color: var(--fg-secondary);
    text-decoration: none;
    font-size: 0.84rem;
    font-weight: 600;
  }

  .src-link:hover {
    color: var(--fg);
    background: var(--bg-elevated);
    border-color: var(--border-strong);
    text-decoration: none;
  }

  .spec-content :global(h1) {
    margin-top: 0;
  }

  .spec-content {
    max-width: 62rem;
  }

  .spec-content :global(pre.astro-code) {
    background: linear-gradient(180deg, #111823 0%, #0b1017 100%) !important;
    border: 1px solid rgba(125, 145, 173, 0.18);
    border-radius: 14px;
    box-shadow:
      0 24px 48px rgba(8, 12, 18, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.02);
  }

  .spec-content :global(pre.astro-code code) {
    font-family: var(--font-mono);
    font-size: 0.84rem;
    line-height: 1.7;
  }

  @media (min-width: 900px) {
    :global(body.spec-page .wrap) {
      max-width: 84rem;
    }

    :global(body.spec-page .spec-content.prose) {
      max-width: 62rem;
    }

    .spec-hero {
      grid-template-columns: minmax(0, 1.15fr) minmax(340px, 0.85fr);
      align-items: start;
      gap: 1.75rem;
      padding-top: 4rem;
    }

    .spec-shell {
      grid-template-columns: 260px minmax(0, 1fr);
      align-items: start;
      gap: 2rem;
    }

    .spec-sidebar {
      position: sticky;
      top: calc(3.5rem + 1rem);
      max-height: calc(100vh - 4.5rem);
      overflow-y: auto;
    }
  }
</style>
